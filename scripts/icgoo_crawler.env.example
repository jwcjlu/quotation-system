# 复制为 .env 或直接在系统环境变量中设置（勿提交真实密码到仓库）
ICGOO_USERNAME=your_phone_or_account
ICGOO_PASSWORD=your_password

# 若出现网易易盾/「搜索过于频繁」，请用有界面浏览器并完成验证，例如：
#   python icgoo_crawler.py --model XXX --no-headless

# 减少「每次登录都弹易盾」：登录成功并保存 Cookie 后，下次用文件跳过登录
# ICGOO_COOKIES_FILE=icgoo_cookies.json
#   python icgoo_crawler.py --model XXX --save-cookies
#   python icgoo_crawler.py --model XXX --cookies-file icgoo_cookies.json

# 多型号时加大间隔，减轻「刷新/频繁访问」触发的易盾与限流，例如：
#   python icgoo_crawler.py --model A,B,C --request-delay 15
