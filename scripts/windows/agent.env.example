# 复制为 agent.env 后按需修改，再运行 install-caichip-agent.ps1 批量写入用户/系统环境变量
# 与 internal/agentapp/config.go LoadConfig 一致

# ========== 必填 ==========
CAICHIP_API_KEY=your-api-key-here

# ========== 服务与身份 ==========
# 默认 http://127.0.0.1:18080
CAICHIP_BASE_URL=http://127.0.0.1:18080
# 留空则每次启动随机 AGENT_ID；生产建议固定
AGENT_ID=
# 默认 default
AGENT_QUEUE=default
# 逗号分隔，如 tag1,tag2
AGENT_TAGS=

# ========== 数据与 Python ==========
# 留空则使用「当前工作目录/agent_data」；建议设为绝对路径
AGENT_DATA_DIR=
# 留空则日志写在 AGENT_DATA_DIR/logs/agent.log（Go/Python agent 均适用；追加写入）
AGENT_LOG_DIR=
# DEBUG|INFO|WARNING|ERROR，默认 INFO
AGENT_LOG_LEVEL=
# 留空则 Windows 用 python，类 Unix 用 python3
CAICHIP_PYTHON=
# 1 或 true 跳过启动前 Python/pip 检查
CAICHIP_SKIP_PYTHON_CHECK=
# 默认 true；设为 0/false/no/off 关闭自动装 Python
CAICHIP_AUTO_INSTALL_PYTHON=

# ========== 超时与并发 ==========
AGENT_LONG_POLL_SEC=10
AGENT_HTTP_TIMEOUT_SEC=120
AGENT_SCRIPT_SYNC_SEC=600
AGENT_MAX_PARALLEL=4
AGENT_PIP_INSTALL_SEC=900
